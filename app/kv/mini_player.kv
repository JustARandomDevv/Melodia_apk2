#:import theme app.theme

<MiniPlayer>:
    orientation: "horizontal"
    padding: [dp(10), dp(6), dp(10), dp(6)]
    spacing: dp(10)

    canvas.before:
        Color:
            rgba: theme.GLASS
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(16)]
        Color:
            rgba: theme.GLASS_BORDER
        Line:
            rounded_rectangle: [self.x, self.y, self.width, self.height, dp(16)]
            width: 1
        Color:
            rgba: theme.ACCENT
        Line:
            points: [self.x + dp(10), self.y, self.x + dp(10) + (self.width - dp(20)) * root.progress, self.y]
            width: 1.6

    ButtonBehavior:
        size_hint: None, 1
        width: dp(46)
        on_release: root.open_now_playing()

        RelativeLayout:
            size_hint: 1, 1
            canvas.before:
                Color:
                    rgba: theme.ACCENT_DIM
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(10)]

            Image:
                source: root.art_source if root.art_source else ""
                allow_stretch: True
                keep_ratio: False
                opacity: 1 if root.art_source else 0
                size: self.parent.size if self.parent else (0, 0)
                pos: self.parent.pos if self.parent else (0, 0)

            MDIcon:
                icon: "music-note"
                pos_hint: {"center_x": 0.5, "center_y": 0.5}
                theme_text_color: "Custom"
                text_color: theme.TEXT_SECONDARY
                opacity: 0 if root.art_source else 1

    ButtonBehavior:
        size_hint: 1, 1
        on_release: root.open_now_playing()

        MDBoxLayout:
            orientation: "vertical"
            padding: [0, dp(2), 0, dp(2)]

            MDLabel:
                text: root.title_text
                font_style: "Label"
                role: "large"
                bold: True
                theme_text_color: "Custom"
                text_color: theme.TEXT_PRIMARY
                shorten: True
                shorten_from: "right"

            MDLabel:
                text: root.artist_text
                font_style: "Label"
                role: "small"
                theme_text_color: "Custom"
                text_color: theme.TEXT_SECONDARY
                shorten: True
                shorten_from: "right"

    MDIconButton:
        icon: "pause" if root.is_playing and not root.is_paused else "play"
        theme_text_color: "Custom"
        text_color: theme.TEXT_PRIMARY
        on_release: root.toggle_pause()

    MDIconButton:
        icon: "skip-next"
        theme_text_color: "Custom"
        text_color: theme.TEXT_PRIMARY
        on_release: root.next_track()
