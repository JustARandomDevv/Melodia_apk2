#:import theme app.theme

<HomeScreen>:
    name: "home"

    MDBoxLayout:
        orientation: "vertical"
        padding: [dp(18), dp(28), dp(18), dp(8)]
        spacing: dp(14)

        MDBoxLayout:
            size_hint_y: None
            height: dp(46)
            spacing: dp(10)

            MDBoxLayout:
                size_hint: None, None
                size: dp(36), dp(36)
                canvas.before:
                    Color:
                        rgba: theme.ACCENT
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(10)]
                MDIcon:
                    icon: "music-note-eighth"
                    pos_hint: {"center_x": 0.5, "center_y": 0.5}
                    theme_text_color: "Custom"
                    text_color: (0.02, 0.05, 0.03, 1)

            MDLabel:
                text: "Melodia"
                font_style: "Headline"
                role: "small"
                bold: True
                theme_text_color: "Custom"
                text_color: theme.TEXT_PRIMARY

        MDLabel:
            text: "Recommandé pour toi"
            font_style: "Title"
            role: "medium"
            theme_text_color: "Custom"
            text_color: theme.TEXT_PRIMARY
            size_hint_y: None
            height: dp(28)

        MDCircularProgressIndicator:
            id: loading_spinner
            active: True
            size_hint: None, None
            size: dp(28), dp(28)
            pos_hint: {"center_x": 0.5}
            theme_color: "Custom"
            color: theme.ACCENT

        ScrollView:
            do_scroll_x: False

            MDBoxLayout:
                id: recs_container
                orientation: "vertical"
                spacing: dp(8)
                size_hint_y: None
                height: self.minimum_height
                padding: [0, 0, 0, dp(90)]
