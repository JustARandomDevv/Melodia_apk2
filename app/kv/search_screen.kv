#:import theme app.theme

<SearchScreen>:
    name: "search"

    MDBoxLayout:
        orientation: "vertical"
        padding: [dp(18), dp(28), dp(18), dp(8)]
        spacing: dp(14)

        MDLabel:
            text: "Recherche"
            font_style: "Headline"
            role: "small"
            bold: True
            theme_text_color: "Custom"
            text_color: theme.TEXT_PRIMARY
            size_hint_y: None
            height: dp(36)

        MDBoxLayout:
            size_hint_y: None
            height: dp(48)

            canvas.before:
                Color:
                    rgba: theme.GLASS
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(14)]
                Color:
                    rgba: theme.GLASS_BORDER
                Line:
                    rounded_rectangle: [self.x, self.y, self.width, self.height, dp(14)]
                    width: 1

            MDIcon:
                icon: "magnify"
                size_hint_x: None
                width: dp(40)
                pos_hint: {"center_y": 0.5}
                theme_text_color: "Custom"
                text_color: theme.TEXT_SECONDARY

            MDTextField:
                id: search_input
                mode: "filled"
                theme_bg_color: "Custom"
                fill_color: (0, 0, 0, 0)
                theme_line_color: "Custom"
                line_color: (0, 0, 0, 0)
                on_text_validate: root.do_search(self.text)

                MDTextFieldHintText:
                    text: "Titre, artiste..."

                MDTextFieldTrailingIcon:
                    icon: "arrow-right-circle"
                    on_release: root.do_search(search_input.text)

        MDCircularProgressIndicator:
            id: loading_spinner
            active: False
            size_hint: None, None
            size: dp(28), dp(28)
            pos_hint: {"center_x": 0.5}
            theme_color: "Custom"
            color: theme.ACCENT

        MDLabel:
            id: empty_label
            text: "Recherche un titre ou un artiste."
            halign: "center"
            theme_text_color: "Custom"
            text_color: theme.TEXT_TERTIARY
            size_hint_y: None
            height: dp(30)

        ScrollView:
            do_scroll_x: False

            MDBoxLayout:
                id: results_container
                orientation: "vertical"
                spacing: dp(8)
                size_hint_y: None
                height: self.minimum_height
                padding: [0, 0, 0, dp(90)]
